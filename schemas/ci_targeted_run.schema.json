{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dev-os.local/schemas/ci_targeted_run.schema.json",
  "title": "CITargetedRun",
  "description": "Round 4A hardening: result of a targeted / related-module test run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ci_policy_version",
    "run_id",
    "repository_identity",
    "command_identity",
    "selection",
    "started_at",
    "finished_at",
    "duration_seconds",
    "final_verdict",
    "failure_class",
    "policy_decision"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "4a.1" },
    "ci_policy_version": { "type": "string", "const": "4a.1" },
    "run_id": { "type": "string" },
    "repository_identity": { "type": "string" },
    "starting_commit": { "type": "string" },
    "compared_base_commit": { "type": ["string", "null"] },
    "command_identity": { "type": "string" },
    "selection": {
      "type": "object",
      "properties": {
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "selected_tests": { "type": "array", "items": { "type": "string" } },
        "unmapped_sources": { "type": "array", "items": { "type": "string" } },
        "broad": { "type": "boolean" },
        "reason": { "type": "string" },
        "rationale": { "type": "object" }
      }
    },
    "started_at": { "type": "string" },
    "finished_at": { "type": "string" },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "exit_status": { "type": ["integer", "null"] },
    "timeout_status": { "type": "boolean" },
    "truncation_status": { "type": "boolean" },
    "ran_full_suite": { "type": "boolean" },
    "tests_passed": { "type": ["integer", "null"] },
    "tests_failed": { "type": ["integer", "null"] },
    "tests_skipped": { "type": ["integer", "null"] },
    "final_verdict": { "type": "string" },
    "failure_class": { "type": "string" },
    "sanitized_output_summary": { "type": "string" },
    "next_action": { "type": "string" },
    "policy_decision": { "type": "string" }
  }
}
