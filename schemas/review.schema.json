{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dev-os.local/schemas/review.schema.json",
  "title": "Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "reviewer_role",
    "verdict",
    "findings",
    "created_at"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "reviewer_role": {
      "type": "string",
      "enum": ["claude", "cursor", "codex"]
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "pass_with_notes", "changes_required", "blocked"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "summary"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["blocker", "major", "minor", "note"]
          },
          "summary": { "type": "string", "minLength": 1 },
          "path": { "type": ["string", "null"] }
        }
      },
      "default": []
    },
    "confirmed_findings": {
      "type": "array",
      "items": { "$ref": "#/properties/findings/items" },
      "default": []
    },
    "rejected_findings": {
      "type": "array",
      "items": { "$ref": "#/properties/findings/items" },
      "default": []
    },
    "notes": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "implementation_report_fingerprint": { "type": ["string", "null"] },
    "content_fingerprint": { "type": ["string", "null"] }
  }
}
