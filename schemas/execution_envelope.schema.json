{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dev-os.local/schemas/execution_envelope.schema.json",
  "title": "ExecutionEnvelope",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "project_id",
    "executable",
    "argument_array",
    "sanitized_working_directory",
    "timeout_status",
    "stdout_truncated",
    "stderr_truncated",
    "execution_status",
    "tests_requested",
    "tests_executed",
    "starting_commit",
    "policy_decision",
    "automation_status"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "3a.1" },
    "execution_id": { "type": "string" },
    "session_id": { "type": "string" },
    "task_id": { "type": ["string", "null"] },
    "project_id": { "type": "string" },
    "executable": { "type": "string" },
    "argument_array": { "type": "array", "items": { "type": "string" } },
    "sanitized_working_directory": { "type": "string" },
    "started_at": { "type": ["string", "null"] },
    "finished_at": { "type": ["string", "null"] },
    "duration_seconds": { "type": ["number", "null"] },
    "exit_code": { "type": ["integer", "null"] },
    "timeout_status": { "type": "boolean" },
    "stdout_truncated": { "type": "boolean" },
    "stderr_truncated": { "type": "boolean" },
    "stdout": { "type": "string" },
    "stderr": { "type": "string" },
    "execution_status": {
      "type": "string",
      "enum": ["success", "failed", "timeout", "rejected", "error"]
    },
    "tests_requested": { "type": "array", "items": { "type": "string" } },
    "tests_executed": { "type": "array", "items": { "type": "string" } },
    "starting_commit": { "type": "string" },
    "resulting_commit": { "type": ["string", "null"] },
    "policy_decision": { "type": "string", "enum": ["allow", "deny"] },
    "rejection_reason": { "type": ["string", "null"] },
    "automation_status": { "type": "string" }
  },
  "additionalProperties": false
}
