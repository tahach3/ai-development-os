{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dev-os.local/schemas/plan.schema.json",
  "title": "Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "task_id",
    "project_id",
    "planner_agent",
    "starting_commit",
    "objective",
    "implementation_steps",
    "testing_plan",
    "files_expected_to_change",
    "status",
    "created_timestamp"
  ],
  "properties": {
    "plan_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "planner_agent": { "type": "string", "minLength": 1 },
    "starting_commit": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "assumptions": { "type": "array", "items": { "type": "string" }, "default": [] },
    "scope": { "type": "array", "items": { "type": "string" }, "default": [] },
    "prohibited_actions": { "type": "array", "items": { "type": "string" }, "default": [] },
    "files_expected_to_change": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "implementation_steps": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "testing_plan": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "rollback_or_recovery_plan": { "type": "array", "items": { "type": "string" }, "default": [] },
    "risks": { "type": "array", "items": { "type": "string" }, "default": [] },
    "unresolved_questions": { "type": "array", "items": { "type": "string" }, "default": [] },
    "approval_requirement": {
      "type": "string",
      "enum": ["none", "human", "human_high_risk"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready_for_approval", "approved", "rejected", "superseded"]
    },
    "created_timestamp": { "type": "string" },
    "approved_timestamp": { "type": ["string", "null"] },
    "approved_by": { "type": ["string", "null"] },
    "approval_note": { "type": ["string", "null"] },
    "content_fingerprint": { "type": ["string", "null"] },
    "approved_fingerprint": { "type": ["string", "null"] },
    "rejection_reason": { "type": ["string", "null"] },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    }
  }
}
