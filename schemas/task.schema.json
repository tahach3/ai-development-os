{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dev-os.local/schemas/task.schema.json",
  "title": "Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "description",
    "project_id",
    "task_type",
    "complexity",
    "risk_level",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "task_type": {
      "type": "string",
      "enum": [
        "feature",
        "bugfix",
        "refactor",
        "docs",
        "review",
        "independent_review",
        "ui",
        "small_fix",
        "verification",
        "architecture",
        "other"
      ]
    },
    "complexity": {
      "type": "string",
      "enum": ["small", "normal", "complex", "high_risk"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready_for_planning",
        "planned",
        "approved_for_implementation",
        "implementing",
        "validating",
        "ready_for_review",
        "review_failed",
        "review_passed",
        "ready_to_commit",
        "completed",
        "blocked",
        "cancelled"
      ]
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "allowed_paths": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "prohibited_paths": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "assigned_role": {
      "type": ["string", "null"],
      "enum": ["claude", "cursor", "codex", null]
    },
    "routing_explanation": { "type": ["string", "null"] },
    "token_budget_band": {
      "type": ["string", "null"],
      "enum": ["small", "normal", "complex", "high_risk", null]
    },
    "parent_task_id": { "type": ["string", "null"] },
    "blocked_reason": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "metadata": { "type": "object", "default": {} }
  }
}
